# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# frontend
/frontend/.next/
/frontend/node_modules
/frontend/**coverage**

# Serwist / next-pwa auto-generated service worker artifacts
/frontend/public/sw.js
/frontend/public/workbox-*.js
/frontend/public/fallback-*.js
/frontend/public/sw.js.map
/frontend/public/workbox-*.js.map
/frontend/public/swe-worker-*.js
/frontend/public/swe-worker-*.js.map

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
/.local-logs
/frontend/.local-logs

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# firebase
*firebase-adminsdk*.json
firestore-debug.log
firebase-debug.log
ui-debug.log

# Firestore client-SDK migration: local-only spike / dev verification tools (not shipped)
/frontend/.spike/
/frontend/app/dev/

# agetns 
.temp
.sessions
.playwright-cli
.playwright-mcp
output/
.claude/codex-logs
.logs/
.demo/
